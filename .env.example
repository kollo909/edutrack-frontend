# ─────────────────────────────────────────────────────────────
# EduTrack Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────
#
# For LOCAL development: copy this file to .env.local
#   cp .env.example .env.local
#
# For PRODUCTION (Vercel): add these in Vercel → Project Settings → Environment Variables

# The full URL of your Spring Boot backend API (no trailing slash)
# Local:       http://localhost:8080/api
# Production:  https://your-app.up.railway.app/api
REACT_APP_API_URL=http://localhost:8080/api
